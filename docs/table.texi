@subheading 综合功能示例

@example
@group
#include "termtools/ui/table.h"
#include "termtools/core/style.h"
#include "termtools/color/color.h"
#include "termtools/core/console.h"
#include <iostream>

using namespace termtools;

void comprehensiveTableExample() @{
    Console console;
    
    Table table;
    
    Table::Column idCol;
    idCol.header = "ID";
    idCol.justify = Justify::Center;
    idCol.width = 6;
    idCol.headerColor = Color(ColorName::Cyan);
    table.addColumn(idCol);
    
    Table::Column nameCol;
    nameCol.header = "产品名称";
    nameCol.minWidth = 15;
    nameCol.headerColor = Color(ColorName::Green);
    table.addColumn(nameCol);
    
    Table::Column priceCol;
    priceCol.header = "价格";
    priceCol.justify = Justify::Right;
    priceCol.width = 10;
    priceCol.headerColor = Color(ColorName::Yellow);
    table.addColumn(priceCol);
    
    Table::Column stockCol;
    stockCol.header = "库存";
    stockCol.justify = Justify::Center;
    stockCol.width = 8;
    stockCol.headerColor = Color(ColorName::Magenta);
    table.addColumn(stockCol);
    
    Table::Column statusCol;
    statusCol.header = "状态";
    statusCol.justify = Justify::Center;
    statusCol.width = 10;
    statusCol.headerColor = Color(ColorName::White);
    table.addColumn(statusCol);
    
    table.addRow(@{"P001", "苹果手机 Pro", "8999.00", "156", "有货"@});
    table.addRow(@{"P002", "笔记本电脑", "6999.00", "42", "有货"@});
    table.addRow(@{"P003", "无线耳机", "299.00", "0", "缺货"@});
    table.addRow(@{"P004", "智能手表", "1999.00", "89", "有货"@});
    table.addRow(@{"P005", "平板电脑", "4599.00", "5", "库存不足"@});
    
    table.addFooterRow(@{"", "总计", "----", "292", ""@});
    
    table.setCellStyleCallback([](int row, int col, const std::string& content) @{
        CellStyle style;
        
        if (col == 2) @{  @r{// 价格列}
            style.color = Color(ColorName::Cyan);
        @} else if (col == 3) @{  @r{// 库存列}
            int stock = std::stoi(content);
            if (stock == 0) @{
                style.color = Color(ColorName::Red);
            @} else if (stock < 10) @{
                style.color = Color(ColorName::Yellow);
            @} else @{
                style.color = Color(ColorName::Green);
            @}
        @} else if (col == 4) @{  @r{// 状态列}
            if (content == "有货") @{
                style.color = Color(ColorName::Green);
                style.style = StyleBuilder().bold();
            @} else if (content == "缺货") @{
                style.color = Color(ColorName::Red);
                style.style = StyleBuilder().bold();
            @} else if (content == "库存不足") @{
                style.color = Color(ColorName::Yellow);
                style.style = StyleBuilder().bold();
            @}
        @}
        
        return style;
    @});
    
    StyleBuilder footerStyle;
    footerStyle.bold().color(Color(ColorName::White));
    table.setFooterStyle(footerStyle);
    
    StyleBuilder headerStyle;
    headerStyle.bold();
    table.setHeaderStyle(headerStyle);
    
    StyleBuilder borderStyle;
    borderStyle.color(Color(ColorName::BrightBlack));
    table.setBorderStyle(borderStyle);
    
    table.setTitle("产品库存管理");
    table.setCaption("更新时间: 2024-01-15 10:30:00");
    table.setBorderType(BorderType::UnicodeRounded);
    table.setZebraStripes(true);
    table.setZebraColors(Color(28, 32, 38), Color(38, 42, 48));
    table.setPadding(1);
    
    console.println(table.render());
@}
@end group
@end example

