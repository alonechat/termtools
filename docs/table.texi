@example
@group
Table table;
table.addColumn("项目").addColumn("金额");

table.addRow(@{"收入", "10000"@});
table.addRow(@{"支出", "6500"@});

table.addFooterRow(@{"合计", "3500"@});
@end group
@end example
@end deftypefn

@subheading 设置页脚样式

@deftypefn {Method} {Table&} setFooterStyle(const StyleBuilder& @var{style})
设置页脚行的全局样式。

@table @var
