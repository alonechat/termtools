页脚样式构建器。
@end table

@return
返回 @code{Table&} 引用，支持链式调用。

@example
@group
Table table;
table.addColumn("项目").addColumn("金额");

table.addRow(@{"收入", "10000"@});
table.addRow(@{"支出", "6500"@});
table.addFooterRow(@{"合计", "3500"@});

StyleBuilder footerStyle;
footerStyle.bold().color(Color(ColorName::Cyan));

table.setFooterStyle(footerStyle);
@end group
@end example
@end deftypefn

@subheading 页脚行示例

