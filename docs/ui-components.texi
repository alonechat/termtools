@end deftypefn

@deftypefn Method static std::string Divider::render @{@} (int @var{width}, const Color &@var{color}, DividerStyle @var{style})
静态方法，渲染分隔线并返回字符串。
@end deftypefn

@deftypefn Method static void Divider::print @{@} (int @var{width}, const Color &@var{color}, DividerStyle @var{style})
静态方法，直接输出分隔线。
@end deftypefn

@node Divider 使用示例
@section Divider 使用示例

@example
@group
#include <termtools/ui/divider.h>
#include <termtools/color/color.h>

using namespace termtools;

int main() @{
    Divider divider;
    divider.setStyle(DividerStyle::Double)
           .setColor(Color(ColorName::Cyan))
           .setWidth(60);
    divider.print();
    
    Divider::print(40, Color(ColorName::Yellow), DividerStyle::Dashed);
    
    return 0;
@}
@end group
@end example

