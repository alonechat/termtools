@subheading 日志表格示例

@example
@group
#include "termtools/ui/table.h"
#include "termtools/core/style.h"
#include "termtools/color/color.h"
#include <iostream>

using namespace termtools;

void logTableExample() @{
    Table table;
    table.addColumn("时间").addColumn("级别").addColumn("消息");
    
    table.addRow(@{"10:30:15", "INFO", "系统启动完成"@});
    table.addRow(@{"10:30:18", "INFO", "数据库连接成功"@});
    table.addRow(@{"10:30:22", "WARN", "内存使用率超过 80%"@});
    table.addRow(@{"10:30:25", "ERROR", "无法连接到缓存服务器"@});
    table.addRow(@{"10:30:28", "INFO", "重试连接成功"@});
    table.addRow(@{"10:30:30", "DEBUG", "请求处理时间: 45ms"@});
    
    table.setCellStyleCallback([](int row, int col, const std::string& content) @{
        CellStyle style;
        
        if (col == 1) @{  @r{// 级别列}
            style.justify = Justify::Center;
            style.style = StyleBuilder().bold();
            
            if (content == "INFO") @{
                style.color = Color(ColorName::Green);
            @} else if (content == "WARN") @{
                style.color = Color(ColorName::Yellow);
            @} else if (content == "ERROR") @{
                style.color = Color(ColorName::Red);
            @} else if (content == "DEBUG") @{
                style.color = Color(ColorName::BrightBlack);
            @}
        @} else if (col == 2) @{  @r{// 消息列}
            if (content.find("ERROR") != std::string::npos ||
                content.find("失败") != std::string::npos) @{
                style.color = Color(ColorName::Red);
            @} else if (content.find("WARN") != std::string::npos) @{
                style.color = Color(ColorName::Yellow);
            @}
        @}
        
        return style;
    @});
    
    table.setTitle("系统日志");
    table.setBorderType(BorderType::ASCII);
    
    std::cout << table.render() << std::endl;
@}
@end group
@end example

