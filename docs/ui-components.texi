    Yellow = 3,
    Blue = 4,
    Magenta = 5,
    Cyan = 6,
    White = 7,
    BrightBlack = 8,
    BrightRed = 9,
    BrightGreen = 10,
    BrightYellow = 11,
    BrightBlue = 12,
    BrightMagenta = 13,
    BrightCyan = 14,
    BrightWhite = 15
@};
@end group
@end example

@subsection Color 构造函数

@deftypefn Constructor Color @{@} ()
创建默认颜色（终端默认颜色）。
@end deftypefn

@deftypefn Constructor Color @{@} (ColorName @var{name})
创建命名颜色。@var{name} 为 ColorName 枚举值。
@end deftypefn

@deftypefn Constructor Color @{@} (uint8_t @var{r}, uint8_t @var{g}, uint8_t @var{b})
创建 RGB 真彩色。@var{r}、@var{g}、@var{b} 分别为红、绿、蓝分量（0-255）。
@end deftypefn

@deftypefn Constructor Color @{@} (uint8_t @var{index256})
创建 256 色索引颜色。@var{index256} 为颜色索引（0-255）。
@end deftypefn

@subsection Color 使用示例

@example
@group
Color named(ColorName::Cyan);           // 命名颜色
Color rgb(255, 128, 0);                 // RGB 颜色
Color indexed(214);                     // 256 色索引
@end group
@end example

@node StyleBuilder 类
@section StyleBuilder 类

StyleBuilder 类用于构建文本样式，定义在头文件 @file{termtools/core/style.h} 中。

@subsection Style 枚举

@example
@group
enum class Style : uint8_t @{
    Bold = 1,
    Dim = 2,
    Italic = 3,
    Underline = 4,
    Blink = 5,
    Reverse = 7,
    Hidden = 8,
    Strikethrough = 9
@};
@end group
@end example

@subsection StyleBuilder 方法

@deftypefn Method StyleBuilder &StyleBuilder::bold @{@} (bool @var{enable} = true)
设置粗体样式。
@end deftypefn

@deftypefn Method StyleBuilder &StyleBuilder::dim @{@} (bool @var{enable} = true)
设置暗淡样式。
@end deftypefn

@deftypefn Method StyleBuilder &StyleBuilder::italic @{@} (bool @var{enable} = true)
设置斜体样式。
@end deftypefn

@deftypefn Method StyleBuilder &StyleBuilder::underline @{@} (bool @var{enable} = true)
设置下划线样式。
@end deftypefn

@deftypefn Method StyleBuilder &StyleBuilder::color @{@} (const Color &@var{color})
设置前景色。
@end deftypefn

@deftypefn Method StyleBuilder &StyleBuilder::bgColor @{@} (const Color &@var{color})
设置背景色。
@end deftypefn

@subsection StyleBuilder 使用示例

@example
@group
StyleBuilder style;
style.bold().italic().color(Color(ColorName::Yellow));

StyleBuilder bgStyle;
bgStyle.bgColor(Color(ColorName::Blue)).color(Color(ColorName::White));
@end group
@end example

@node Text 类
@section Text 类

Text 类用于构建带样式的文本，定义在头文件 @file{termtools/text/text.h} 中。

@subsection Text 构造函数

@deftypefn Constructor Text @{@} ()
创建空的 Text 对象。
@end deftypefn

@deftypefn Constructor Text @{@} (const std::string &@var{content})
创建指定内容的 Text 对象。
@end deftypefn

@deftypefn Constructor Text @{@} (const std::string &@var{content}, const Color &@var{color})
创建指定内容和颜色的 Text 对象。
@end deftypefn

@deftypefn Constructor Text @{@} (const std::string &@var{content}, const StyleBuilder &@var{style})
创建指定内容和样式的 Text 对象。
@end deftypefn

@subsection Text 方法

@deftypefn Method Text &Text::append @{@} (const Text &@var{other})
追加 Text 对象。
@end deftypefn

@deftypefn Method Text &Text::append @{@} (const std::string &@var{str})
追加字符串。
@end deftypefn

@deftypefn Method Text &Text::append @{@} (const std::string &@var{str}, const Color &@var{color})
追加带颜色的字符串。
@end deftypefn

@deftypefn Method Text &Text::styled @{@} (const StyleBuilder &@var{style})
应用样式。
@end deftypefn

@deftypefn Method Text &Text::colored @{@} (const Color &@var{color})
应用颜色。
@end deftypefn

@deftypefn Method std::string Text::render @{@} () const
渲染并返回 ANSI 格式化字符串。
@end deftypefn

@deftypefn Method std::string Text::plain @{@} () const
返回去除 ANSI 转义序列的纯文本。
@end deftypefn

@subsection Text 使用示例

@example
@group
Text text("Hello ");
text.append("World", Color(ColorName::Green))
    .append("!")
    .styled(StyleBuilder().bold());
std::cout << text.render() << std::endl;
@end group
@end example

