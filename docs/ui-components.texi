@deftypefn Method std::string Heading::render @{@} () const
渲染标题并返回 ANSI 格式化字符串。
@end deftypefn

@deftypefn Method void Heading::print @{@} () const
将标题输出到标准输出。
@end deftypefn

@node Heading 使用示例
@section Heading 使用示例

@example
@group
#include <termtools/ui/heading.h>
#include <termtools/color/color.h>

using namespace termtools;

int main() @{
    Heading h1(HeadingLevel::H1, "主标题");
    h1.setColor(Color(ColorName::Cyan))
      .setBold(true);
    h1.print();

    Heading h2(HeadingLevel::H2, "副标题");
    h2.setColor(Color(ColorName::Yellow))
      .print();
    
    Heading::print(HeadingLevel::H3, "快速标题", Color(ColorName::Green));
    
    return 0;
@}
@end group
@end example

