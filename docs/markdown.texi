@subheading 示例 4：使用预设颜色

@example
MarkdownConfig createPresetTheme() @{
    MarkdownConfig config;
    config.headingColor(Color(ColorName::BrightCyan))
          .codeColor(Color(ColorName::BrightYellow))
          .linkColor(Color(ColorName::BrightBlue))
          .quoteColor(Color(ColorName::BrightGreen))
