    Table table;
    table.addColumn("ID").addColumn("任务").addColumn("优先级").addColumn("状态").addColumn("负责人");
    
    table.addRow(@{"T001", "实现用户登录功能", "高", "进行中", "张三"@});
    table.addRow(@{"T002", "设计数据库架构", "高", "完成", "李四"@});
    table.addRow(@{"T003", "编写单元测试", "中", "待处理", "王五"@});
    table.addRow(@{"T004", "优化查询性能", "低", "待处理", "赵六"@});
    table.addRow(@{"T005", "修复登录 Bug", "高", "进行中", "张三"@});
    table.addRow(@{"T006", "更新文档", "低", "完成", "钱七"@});
    
    table.setCellStyleCallback([](int row, int col, const std::string& content) @{
        CellStyle style;
        
        if (col == 0) @{  @r{// ID 列}
            style.color = Color(ColorName::Cyan);
            style.style = StyleBuilder().bold();
        @} else if (col == 2) @{  @r{// 优先级列}
            style.justify = Justify::Center;
            if (content == "高") @{
                style.color = Color(ColorName::Red);
                style.style = StyleBuilder().bold();
            @} else if (content == "中") @{
                style.color = Color(ColorName::Yellow);
            @} else @{
                style.color = Color(ColorName::BrightBlack);
            @}
        @} else if (col == 3) @{  @r{// 状态列}
            style.justify = Justify::Center;
            if (content == "完成") @{
                style.color = Color(ColorName::Green);
            @} else if (content == "进行中") @{
                style.color = Color(ColorName::Blue);
            @} else @{
                style.color = Color(ColorName::BrightBlack);
            @}
        @}
        
        return style;
    @});
    
    table.setTitle("项目任务列表");
    table.setBorderType(BorderType::Unicode);
    table.setZebraStripes(true);
    table.setZebraColors(Color(30, 30, 35), Color(40, 40, 45));
    
    std::cout << table.render() << std::endl;
@}
@end group
@end example

