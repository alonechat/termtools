@node 输入验证示例
@subsection 输入验证示例

@cindex 输入验证
@cindex 实际应用

本节提供一些实际应用场景中的综合示例，展示如何结合多种输入方法构建完整的交互流程。

@subheading 示例一：用户注册流程

@example
#include <termtools/input/prompt.h>
#include <iostream>
#include <vector>

int main() @{
    std::cout << "=== 用户注册 ===" << std::endl;
    
    // 基本信息
    std::string username = termtools::Prompt::ask("请输入用户名");
    std::string email = termtools::Prompt::ask("请输入邮箱地址");
    
    // 密码设置
    std::string password;
    while (true) @{
        password = termtools::Prompt::askPassword("请设置密码（至少6位）");
        if (password.length() >= 6) @{
            std::string confirm = termtools::Prompt::askPassword("请确认密码");
            if (password == confirm) @{
                break;
            @} else @{
                std::cout << "两次密码不一致，请重新设置" << std::endl;
            @}
        @} else @{
            std::cout << "密码长度不足6位，请重新设置" << std::endl;
        @}
    @}
    
    // 年龄验证
    int age = termtools::Prompt::askInt("请输入年龄", 0, 150);
    
    // 性别选择
    std::vector<std::string> genders = @{"男", "女", "其他"@};
    std::string gender = termtools::Prompt::askChoice("请选择性别", genders);
    
    // 兴趣爱好
    std::vector<std::string> interests = @{
        "技术", "艺术", "体育", "音乐", "阅读", "旅行"
    @};
    std::vector<std::string> hobbies = 
        termtools::Prompt::askMultipleChoice("请选择兴趣爱好", interests);
    
    // 确认注册
    std::cout << "\n=== 注册信息确认 ===" << std::endl;
    std::cout << "用户名：" << username << std::endl;
    std::cout << "邮箱：" << email << std::endl;
    std::cout << "年龄：" << age << std::endl;
    std::cout << "性别：" << gender << std::endl;
    
    if (termtools::Prompt::confirm("确认提交注册信息？")) @{
        std::cout << "注册成功！" << std::endl;
    @} else @{
        std::cout << "注册已取消" << std::endl;
    @}
    
    return 0;
@}
@end example

@subheading 示例二：配置向导

@example
#include <termtools/input/prompt.h>
#include <iostream>
#include <vector>

int main() @{
    std::cout << "=== 项目配置向导 ===" << std::endl;
    
    // 项目名称
    std::string projectName = termtools::Prompt::ask("请输入项目名称", "my-project");
    
    // 项目类型
    std::vector<std::string> projectTypes = @{
        "Web应用", "命令行工具", "库/框架", "桌面应用"
    @};
    std::string projectType = termtools::Prompt::askChoice(
        "请选择项目类型", projectTypes, "Web应用");
    
    // 编程语言
    std::vector<std::string> languages = @{
        "C++", "Python", "JavaScript", "Go", "Rust"
    @};
    std::string language = termtools::Prompt::askChoice(
        "请选择主要编程语言", languages);
    
    // 端口号（如果是Web应用）
    int port = 8080;
    if (projectType == "Web应用") @{
        port = termtools::Prompt::askInt("请输入端口号", 8080, 1, 65535);
    @}
    
    // 功能模块
    std::vector<std::string> modules = @{
        "用户认证", "数据库连接", "日志系统", 
        "API文档", "单元测试", "CI/CD配置"
    @};
    std::vector<std::string> selectedModules = 
        termtools::Prompt::askMultipleChoice("请选择需要的功能模块", modules);
    
    // 是否启用详细日志
    bool verbose = termtools::Prompt::confirm("是否启用详细日志输出？", false);
    
    // 输出配置摘要
    std::cout << "\n=== 配置摘要 ===" << std::endl;
    std::cout << "项目名称：" << projectName << std::endl;
    std::cout << "项目类型：" << projectType << std::endl;
    std::cout << "编程语言：" << language << std::endl;
    if (projectType == "Web应用") @{
        std::cout << "端口：" << port << std::endl;
    @}
    std::cout << "功能模块：" << selectedModules.size() << " 个" << std::endl;
    std::cout << "详细日志：" << (verbose ? "是" : "否") << std::endl;
    
    if (termtools::Prompt::confirm("确认生成项目？")) @{
        std::cout << "正在生成项目..." << std::endl;
    @}
    
    return 0;
@}
@end example

@subheading 示例三：数据录入系统

@example
#include <termtools/input/prompt.h>
#include <iostream>
#include <vector>
#include <iomanip>

struct Product @{
    std::string name;
    float price;
    int quantity;
    std::string category;
@};

int main() @{
    std::cout << "=== 商品录入系统 ===" << std::endl;
    
    std::vector<Product> products;
    std::vector<std::string> categories = @{
        "电子产品", "服装", "食品", "图书", "其他"
    @};
    
    while (true) @{
        std::cout << "\n--- 录入新商品 ---" << std::endl;
        
        // 商品名称
        std::string name = termtools::Prompt::ask("商品名称");
        
        // 商品价格
        float price = termtools::Prompt::askFloat(
            "商品价格（元）", 0.01f, 0.01f, 1000000.0f);
        
        // 商品数量
        int quantity = termtools::Prompt::askInt("库存数量", 0, 1000000);
        
        // 商品类别
        std::string category = termtools::Prompt::askChoice(
            "商品类别", categories);
        
        // 添加到列表
        products.push_back(@{name, price, quantity, category@});
        
        // 是否继续
        if (!termtools::Prompt::confirm("是否继续录入？", false)) @{
            break;
        @}
    @}
    
    // 显示录入结果
    std::cout << "\n=== 录入完成 ===" << std::endl;
    std::cout << std::left << std::setw(20) << "商品名称"
              << std::setw(10) << "价格" 
              << std::setw(10) << "数量"
              << "类别" << std::endl;
    std::cout << std::string(50, '-') << std::endl;
    
    float totalValue = 0.0f;
    for (const auto& p : products) @{
        std::cout << std::left << std::setw(20) << p.name
                  << std::setw(10) << std::fixed << std::setprecision(2) << p.price
                  << std::setw(10) << p.quantity
                  << p.category << std::endl;
        totalValue += p.price * p.quantity;
    @}
    
    std::cout << std::string(50, '-') << std::endl;
    std::cout << "总商品数：" << products.size() << " 种" << std::endl;
    std::cout << "总库存价值：" << std::fixed << std::setprecision(2) 
              << totalValue << " 元" << std::endl;
    
    return 0;
@}
@end example

@subheading 示例四：游戏设置菜单

@example
#include <termtools/input/prompt.h>
#include <iostream>
#include <vector>

int main() @{
    std::cout << "=== 游戏设置 ===" << std::endl;
    
    // 难度选择
    std::vector<std::string> difficulties = @{
        "简单", "普通", "困难", "地狱"
    @};
    std::string difficulty = termtools::Prompt::askChoice(
        "选择游戏难度", difficulties, "普通");
    
    // 音量设置
    int masterVolume = termtools::Prompt::askInt(
        "主音量", 80, 0, 100);
    int musicVolume = termtools::Prompt::askInt(
        "音乐音量", 70, 0, 100);
    int sfxVolume = termtools::Prompt::askInt(
        "音效音量", 90, 0, 100);
    
    // 画面设置
    std::vector<std::string> resolutions = @{
        "1280x720", "1920x1080", "2560x1440", "3840x2160"
    @};
    std::string resolution = termtools::Prompt::askChoice(
        "分辨率", resolutions, "1920x1080");
    
    // 图形质量
    std::vector<std::string> qualities = @{
        "低", "中", "高", "超高"
    @};
    std::string quality = termtools::Prompt::askChoice(
        "图形质量", qualities, "高");
    
    // 帧率限制
    std::vector<int> fpsOptions = @{30, 60, 120, 144, 0@};  // 0表示不限制
    int fps = termtools::Prompt::askInt(
        "帧率限制（0为不限制）", 60, 0, 300);
    
    // 游戏功能开关
    bool fullscreen = termtools::Prompt::confirm("全屏模式？", true);
    bool vsync = termtools::Prompt::confirm("垂直同步？", true);
    bool subtitles = termtools::Prompt::confirm("显示字幕？", true);
    
    // 输出设置
    std::cout << "\n=== 当前设置 ===" << std::endl;
    std::cout << "难度：" << difficulty << std::endl;
    std::cout << "音量 - 主：" << masterVolume 
              << "%, 音乐：" << musicVolume 
              << "%, 音效：" << sfxVolume << "%" << std::endl;
    std::cout << "分辨率：" << resolution << std::endl;
    std::cout << "图形质量：" << quality << std::endl;
    std::cout << "帧率限制：" << (fps == 0 ? "不限制" : std::to_string(fps)) << std::endl;
    std::cout << "全屏：" << (fullscreen ? "是" : "否") << std::endl;
    std::cout << "垂直同步：" << (vsync ? "是" : "否") << std::endl;
    std::cout << "字幕：" << (subtitles ? "是" : "否") << std::endl;
    
    if (termtools::Prompt::confirm("保存设置？")) @{
        std::cout << "设置已保存！" << std::endl;
    @}
    
    return 0;
@}
@end example

