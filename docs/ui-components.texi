@deftypefn Method ListType List::getType @{@} () const
获取列表类型。
@end deftypefn

@deftypefn Method std::vector<ListItem> List::getItems @{@} () const
获取所有列表项。
@end deftypefn

@deftypefn Method std::string List::render @{@} () const
渲染列表并返回 ANSI 格式化字符串。
@end deftypefn

@deftypefn Method void List::print @{@} () const
将列表输出到标准输出。
@end deftypefn

@node List 使用示例
@section List 使用示例

@example
@group
#include <termtools/ui/list.h>
#include <termtools/color/color.h>

using namespace termtools;

int main() @{
    List unorderedList(ListType::Unordered);
    unorderedList.addItem("第一项")
                  .addItem("第二项")
                  .addItem("第三项")
                  .setColor(Color(ColorName::Green));
    unorderedList.print();

    List orderedList(ListType::Ordered);
    orderedList.addItem("步骤一")
               .addItem("步骤二")
               .addItem("步骤三")
               .setStartNumber(1);
    orderedList.print();

    ListItem item("嵌套项目");
    item.setIndent(1);
    List nestedList;
    nestedList.addItem("主项目")
              .addItem(item);
    nestedList.print();
    
    return 0;
@}
@end group
@end example

